{
  "buildCommand": "cd EasyPortrait && npm install && npm run build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/portrait/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.svg|.*\\.ico|.*\\.woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/portrait/assets/(.*)",
      "dest": "/EasyPortrait/dist/assets/$1"
    },
    {
      "src": "/portrait/vite\\.svg",
      "dest": "/EasyPortrait/dist/vite.svg"
    },
    {
      "src": "/portrait/(.*\\.(js|css|png|jpg|jpeg|svg|ico|woff|woff2|wasm|mjs))",
      "dest": "/EasyPortrait/dist/$1"
    },
    {
      "src": "/portrait(/.*)?",
      "dest": "/EasyPortrait/dist/index.html"
    },
    {
      "src": "/guides/([^/]+)/$",
      "dest": "/guides/$1/index.html"
    },
    {
      "src": "/guides/([^/]+)$",
      "dest": "/guides/$1/index.html"
    },
    {
      "src": "/guides/(.*\\.(css|js|png|jpg|jpeg|svg|ico|woff|woff2))",
      "dest": "/guides/$1"
    },
    {
      "src": "/guides/?$",
      "dest": "/guides/index.html"
    },
    {
      "src": "/srt-editor/(.*)",
      "dest": "/srt-editor/$1"
    },
    {
      "src": "/srt-editor",
      "dest": "/srt-editor/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
