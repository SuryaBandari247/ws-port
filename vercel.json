{
  "buildCommand": "cd EasyPortrait && npm install && npm run build",
  "outputDirectory": ".",
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/portrait/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.svg|.*\\.ico|.*\\.woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/portrait/assets/:path*", "destination": "/EasyPortrait/dist/assets/:path*" },
    { "source": "/portrait/vite.svg", "destination": "/EasyPortrait/dist/vite.svg" },
    { "source": "/portrait/:path*", "destination": "/EasyPortrait/dist/index.html" },
    { "source": "/portrait", "destination": "/EasyPortrait/dist/index.html" }
  ]
}
